# Copie para application/.env e ajuste conforme o ambiente.

# Ambiente
APP_ENVIRONMENT=production

# Deploy GitHub/VPS
ALLOW_WEB_DEPLOY=false
DEPLOY_BRANCH=main
DEPLOY_SCRIPT_PATH=scripts/deploy.sh
DEPLOY_LOG_FILE=application/logs/deploy.log
DEPLOY_LOCK_FILE=application/cache/deploy.lock
DEPLOY_LOG_TAIL_LINES=120
CLEAR_DEPLOY_LOG_ON_START=1
DEPLOY_GITHUB_REPO=
DEPLOY_GITHUB_WORKFLOW=deploy.yml
DEPLOY_GITHUB_TOKEN=
